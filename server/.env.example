# SecureFlow server environment variables
# Copy this file to .env and fill in the values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/secureflow

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-a-strong-random-secret>
JWT_REFRESH_SECRET=<generate-a-different-strong-random-secret>

# Server port (default: 5000)
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# Frontend origin for CORS (default: http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# Public URL of this server (used in GitHub check runs / PR comments / scan links)
SERVER_URL=http://localhost:5000

# ── Phase 2: GitHub App ────────────────────────────────────────────────────

# Numeric App ID shown on the GitHub App settings page
GITHUB_APP_ID=<your-github-app-id>

# RSA private key generated when you created the GitHub App (PEM format).
# Replace literal newlines with \n so the value fits on one line, e.g.:
#   GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_PRIVATE_KEY=<pem-private-key-with-\\n-for-newlines>

# Webhook secret configured on the GitHub App settings page.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_WEBHOOK_SECRET=<generate-a-strong-random-secret>
